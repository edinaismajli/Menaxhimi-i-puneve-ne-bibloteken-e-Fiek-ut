<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" styleClass="page" xmlns:fx="http://javafx.com/fxml" fx:controller="library_fiek.controllers.LoansController">
    <Label text="%loans.title" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
    <GridPane hgap="8" vgap="8">
        <Label text="%field.bookId" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="bookIdField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="%field.memberId" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="memberIdField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="%field.dueDate" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dueDatePicker" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>
    <HBox spacing="8">
        <Button text="%loans.create" onAction="#addLoan"/>
        <Button text="%loans.returnSelected" onAction="#returnLoan"/>
    </HBox>
    <TableView fx:id="loansTable">
        <columns>
            <TableColumn fx:id="idColumn" text="%column.id" prefWidth="60"/>
            <TableColumn fx:id="bookIdColumn" text="%field.bookId" prefWidth="90"/>
            <TableColumn fx:id="memberIdColumn" text="%field.memberId" prefWidth="100"/>
            <TableColumn fx:id="loanDateColumn" text="%field.loanDate" prefWidth="120"/>
            <TableColumn fx:id="dueDateColumn" text="%field.dueDate" prefWidth="120"/>
            <TableColumn fx:id="returnDateColumn" text="%field.returnDate" prefWidth="120"/>
            <TableColumn fx:id="statusColumn" text="%field.status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>