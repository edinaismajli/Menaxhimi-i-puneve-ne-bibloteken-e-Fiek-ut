<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" styleClass="page" xmlns:fx="http://javafx.com/fxml" fx:controller="library_fiek.controllers.DatabaseController">
    <Label text="%database.title" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
    <HBox spacing="8">
        <Button text="%database.testConnection" onAction="#testConnection"/>
        <Button text="%database.refreshData" onAction="#refreshData"/>
        <Label fx:id="connectionStatusLabel" text="%database.notTested"/>
    </HBox>
    <TableView fx:id="databaseTable">
        <columns>
            <TableColumn fx:id="idColumn" text="%field.loanId" prefWidth="80"/>
            <TableColumn fx:id="bookIdColumn" text="%field.bookId" prefWidth="100"/>
            <TableColumn fx:id="memberIdColumn" text="%field.memberId" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="%field.status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>