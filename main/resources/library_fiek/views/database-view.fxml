<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12"
      styleClass="page"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="library_fiek.controllers.DatabaseController">

    <Label text="Database" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <Button text="Test Connection" onAction="#testConnection"/>
        <Button text="Refresh Data" onAction="#refreshData"/>
        <Label fx:id="connectionStatusLabel" text="Not tested"/>
    </HBox>

    <TableView fx:id="databaseTable">
        <columns>
            <TableColumn fx:id="idColumn" text="Loan ID" prefWidth="80"/>
            <TableColumn fx:id="bookIdColumn" text="Book ID" prefWidth="100"/>
            <TableColumn fx:id="memberIdColumn" text="Member ID" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
