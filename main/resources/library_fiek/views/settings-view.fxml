<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="settingsRoot" spacing="12" styleClass="page" xmlns:fx="http://javafx.com/fxml" fx:controller="library_fiek.controllers.SettingsController">
    <Label text="%settings.title" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
    <VBox spacing="6" styleClass="info-panel">
        <Label text="%menu.language"/>
        <RadioButton fx:id="albanianRadio" text="Shqip"/>
        <RadioButton fx:id="englishRadio" text="English"/>
    </VBox>
    <VBox spacing="6" styleClass="info-panel">
        <Label text="%settings.accessibility"/>
        <CheckBox fx:id="largeTextCheckBox" text="%settings.largeText"/>
    </VBox>
    <Button text="%settings.save" onAction="#saveSettings"/>
</VBox>