<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12"
      styleClass="page"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="library_fiek.controllers.HelpController">

    <Label text="Help" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TextArea fx:id="helpTextArea"
              editable="false"
              wrapText="true"
              prefRowCount="18"/>

</VBox>
